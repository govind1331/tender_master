# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tender_db
POSTGRES_USER=tender_user
POSTGRES_PASSWORD=tender_pass

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SIMILARITY_THRESHOLD=0.75

# ── Ollama (LLM inference — runs as a sidecar container) ─────────────────────
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.2:3b          # options: mistral, llama3, gemma2, phi3

# ── HuggingFace Embeddings (local, no API key needed) ────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2   # 384-dim — fast, CPU-friendly
EMBEDDING_DIM=384
# For higher quality (needs more RAM): all-mpnet-base-v2 → set EMBEDDING_DIM=768
